{
  "manifest_version": 3,
  "name": "BlobAnywhere",
  "version": "1.0",
  "description": "Spawn and customize versatile softbody blobs on any website.",
  "author": "K4R33M4Q",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
